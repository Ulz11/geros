[Unit]
Description=GerOS (PocketBase) — camp management
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=geros
Group=geros
WorkingDirectory=/opt/geros
ExecStart=/opt/geros/pocketbase serve --http=127.0.0.1:8090
Restart=on-failure
RestartSec=5
# hardening — this box holds the camp's books
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/geros

[Install]
WantedBy=multi-user.target
